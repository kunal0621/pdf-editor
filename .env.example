# ==== FRONTEND (web/.env.local) ====
NEXT_PUBLIC_API_BASE_URL="http://localhost:8000"
NEXT_PUBLIC_SUPABASE_URL="https://yourprojectid.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
NEXT_PUBLIC_SUPABASE_BUCKET="pdf-bucket"

# ==== BACKEND (api/.env) ====
# Supabase Auth Secret
SUPABASE_JWT_SECRET="your-jwt-secret-from-supabase-settings"

# Supabase S3 bucket configuration
S3_ENDPOINT_URL="https://yourprojectid.supabase.co/storage/v1/s3"
S3_ACCESS_KEY_ID="your-s3-access-key"
S3_SECRET_ACCESS_KEY="your-s3-secret-key"
S3_BUCKET_NAME="pdf-bucket"
S3_REGION="us-east-1"

# FastAPI configuration
PDF_EDITOR_MAX_UPLOAD_MB=25
PDF_EDITOR_CORS_ORIGINS=http://localhost:3000
